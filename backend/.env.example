# Copy this file to .env and fill in your values.
# NEVER commit .env — it is listed in .gitignore.

# Path to the Firebase Admin SDK service account JSON.
# Download from: Firebase Console → Project Settings → Service Accounts → Generate new private key
GOOGLE_APPLICATION_CREDENTIALS=./database/YOUR-PROJECT-adminsdk-XXXXX.json

# Your Firebase project ID (visible in Firebase Console → Project Settings)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Port the Express server listens on
PORT=3001

# Comma-separated list of allowed CORS origins (no spaces)
# Development default: http://localhost:5173
# Production example: https://yourapp.web.app,https://yourapp.com
ALLOWED_ORIGINS=http://localhost:5173

# Apify — get from apify.com → Settings → Integrations → API token
APIFY_TOKEN=your-apify-api-token
# The dataset ID from a completed Apify actor run (visible in the run detail page)
APIFY_DATASET_ID=your-dataset-id

# Gemini — get from aistudio.google.com → Get API key
GEMINI_API_KEY=your-gemini-api-key
